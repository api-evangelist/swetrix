                "description": "Number of results to skip for pagination"
              }
            ]
          },
          "docs": "Returns a paginated list of error event groups for the specified project and time period."
        },
        {
          "info": {
            "name": "Get Error Details",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.swetrix.com/v1/log/get-error",
            "params": [
              {
                "name": "pid",
                "value": "",
                "type": "query",
                "description": "Project ID"
              },
              {
                "name": "eid",
